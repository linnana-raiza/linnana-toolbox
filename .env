WINDOW_WIDTH='1080'
WINDOW_HEIGHT='720'
WINDOW_X='700'
WINDOW_Y='300'

TODO_X='25'
TODO_Y='25'
TODO_H='380'
TODO_W='320'
TODO_MINIMIZED='false'

WALLPAPER_TYPE='static'
MUSIC_VOLUME='0.06'

LAST_MUSIC_TIME='0'
LAST_MUSIC_NAME=' '

## 时钟设置 BEGIN # 调整桌面时钟的外观
CLOCK_SIZE='4' # [range:2:10:0.5] 时钟大小 (范围2-10)
CLOCK_COLOR='#ffffff' # [color] 时钟颜色
CLOCK_STROKE='2' # [range:0:5:0.1] 字体描边粗细(像素)
## 时钟设置 END

## 壁纸设置 BEGIN # 个性化你的工具箱背景
STATIC_WALLPAPER='wallpaper-static.jpg' # [upload:static] 
DYNAMIC_WALLPAPER='wallpaper-dynamic.mp4' # [upload:dynamic] 
## 壁纸设置 END

## Live2D 设置 BEGIN # 调整live2d的位置和大小
LIVE2D_WALLPAPER=' ' # [select:live2d] 选择live2d
LIVE2D_VOLUME='0.1' # [range:0:1:0.05] live2d音量
LIVE2D_SCALE='1' # [range:0.1:4:0.1] 模型缩放比例
LIVE2D_X='0' # [range:-1000:1000:10] 水平偏移 (负数靠左，正数靠右)
LIVE2D_Y='0' # [range:-1000:1000:10] 垂直偏移 (负数靠上，正数靠下)
## Live2D 设置 END

## 语音转文字(STT)设置 BEGIN # 全局极速语音输入助手
STT_HOTKEY='f4' # 全局快捷键(按住说话，松开识别并复制) [hotkey]
STT_MODEL_SIZE='base' # 模型大小 [select:tiny,base,small,medium,large-v3]
STT_DEVICE='cpu' # 计算设备 [select:cpu,cuda,auto]
## 语音转文字(STT)设置 END

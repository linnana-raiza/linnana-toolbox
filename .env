WINDOW_WIDTH='1080'
WINDOW_HEIGHT='720'
WINDOW_X='200'
WINDOW_Y='200'

TODO_X='10'
TODO_Y='20'
TODO_H='500'
TODO_W='400'
TODO_MINIMIZED='false'

## 时钟设置 BEGIN # 调整桌面时钟的外观
CLOCK_SIZE='4' # [range:2:10:0.5] 时钟大小 (范围2-10)
CLOCK_COLOR='#ffffff' # [color] 时钟颜色
CLOCK_STROKE='2.5' # [range:0:5:0.1] 字体描边粗细(像素)
## 时钟设置 END

## 壁纸路径 BEGIN # 上传你的个性化壁纸
STATIC_WALLPAPER=' ' # [upload:static] 静态壁纸
DYNAMIC_WALLPAPER=' ' # [upload:dynamic] 动态壁纸
WALLPAPER_TYPE='static' # 当前壁纸类型
## 壁纸路径 END

## Live2D 设置 BEGIN # 调整live2d的位置和大小
LIVE2D_WALLPAPER='live2d/10101/Lead_00.model.json' # [select:live2d] 选择live2d
LIVE2D_SCALE='1' # [range:0.1:4:0.1] 模型缩放比例
LIVE2D_X='0' # [range:-1000:1000:10] 水平偏移 (负数靠左，正数靠右)
LIVE2D_Y='0' # [range:-1000:1000:10] 垂直偏移 (负数靠上，正数靠下)
## Live2D 设置 END

## 语音转文字(STT)设置 BEGIN # 全局极速语音输入助手
STT_HOTKEY='f4' # 全局快捷键(按住说话，松开识别并复制)
STT_MODEL_SIZE='base' # 模型大小(填入: tiny, base, small, medium)
STT_DEVICE='auto' # 计算设备(填入: cpu, cuda, auto)
## 语音转文字(STT)设置 END